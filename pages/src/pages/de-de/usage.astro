import { joinURL, withTrailingSlash } from "ufo";

import { defaultContentSecurityPolicy } from "../../lib/csp.mjs";
import { GITHUB_OWNER, GITHUB_REPO, PRODUCTION_BASE_URL } from "../../lib/info.mjs";

const { BASE_URL, PROD } = import.meta.env;
const GITHUB_SHA = import.meta.env.GITHUB_SHA?.trim();

const lang = "de-de";
---

<!doctype html>
<html lang="de-de">
<head>
<meta charset="utf-8" />
{ PROD && (<meta http-equiv="Content-Security-Policy" content={defaultContentSecurityPolicy.join(" ")} />) }
<title>Verwendung - Live Background Removal Lite</title>
<meta name="description" content="Eine leistungsstarke, absturzsichere Hintergrundentfernung für OBS Studio mit Fokus auf Gaming." />
<meta name="viewport" content="width=device-width" />
<meta name="revision" content={GITHUB_SHA ?? "undefined"} />
<meta name="github-repo" content="kaito-tokyo/live-backgroundremoval-lite" />
<link rel="icon" type="image/svg+xml" href={joinURL(BASE_URL, "favicon.svg")} />
<link rel="shortcut icon" href={joinURL(BASE_URL, "favicon.ico")} />
<link rel="stylesheet" href={joinURL(BASE_URL, "styles", "global.css")} />
<link rel="canonical" href={withTrailingSlash(joinURL(PRODUCTION_BASE_URL, lang, "usage"))} />
<link rel="alternate" hreflang="x-default" href={withTrailingSlash(joinURL(PRODUCTION_BASE_URL, "usage"))} />
<link rel="alternate" hreflang="en" href={withTrailingSlash(joinURL(PRODUCTION_BASE_URL, "en", "usage"))} />
<link rel="alternate" hreflang="de-de" href={withTrailingSlash(joinURL(PRODUCTION_BASE_URL, "de-de", "usage"))} />
<link rel="alternate" hreflang="es-es" href={withTrailingSlash(joinURL(PRODUCTION_BASE_URL, "es-es", "usage"))} />
<link rel="alternate" hreflang="fr-fr" href={withTrailingSlash(joinURL(PRODUCTION_BASE_URL, "fr-fr", "usage"))} />
<link rel="alternate" hreflang="ja-jp" href={withTrailingSlash(joinURL(PRODUCTION_BASE_URL, "ja-jp", "usage"))} />
<link rel="alternate" hreflang="ko-kr" href={withTrailingSlash(joinURL(PRODUCTION_BASE_URL, "ko-kr", "usage"))} />
<link rel="alternate" hreflang="pt-br" href={withTrailingSlash(joinURL(PRODUCTION_BASE_URL, "pt-br", "usage"))} />
<link rel="alternate" hreflang="ru-ru" href={withTrailingSlash(joinURL(PRODUCTION_BASE_URL, "ru-ru", "usage"))} />
<link rel="alternate" hreflang="zh-cn" href={withTrailingSlash(joinURL(PRODUCTION_BASE_URL, "zh-cn", "usage"))} />
<link rel="alternate" hreflang="zh-tw" href={withTrailingSlash(joinURL(PRODUCTION_BASE_URL, "zh-tw", "usage"))} />
<script is:inline src={joinURL(BASE_URL, "scripts", "LanguageSwitcher.js")}></script>
</head>
<body id="site-usage">

<nav class="language-switcher" aria-label="Sprachumschalter">
<language-switcher><button lang="en" translate="no">🌐 Language</button></language-switcher>
<script>document.querySelector("nav.language-switcher button")?.addEventListener("click", LanguageSwitcherElement.onClick);</script>
</nav>

<main class="white-box">

<hgroup>
<h1>Verwendung</h1>
<h2>Live Background Removal Lite</h2>
</hgroup>

<section id="adding-filter">
<h2>Den Filter hinzufügen</h2>
<img
src={joinURL(BASE_URL, "effect-filters.webp")}
alt="Screenshot des OBS-Studio-Fensters 'Filter', in dem 'Live Background Removal Lite' aus der Liste der Effektfilter ausgewählt wird."
width="1552"
height="1032"
fetchpriority="high"
/
>
<ol>
<li>Klicke in OBS Studio im Bereich "Quellen" mit der rechten Maustaste auf deine Videoquelle, z. B. deine Webcam.</li>
<li>Wähle im Kontextmenü <b>Filter</b> aus.</li>
<li>Klicke im Fenster "Filter" im Abschnitt "Effektfilter" auf die Schaltfläche <b>+</b>, um einen neuen Filter hinzuzufügen.</li>
<li>Wähle aus der Liste der verfügbaren Filter <b>Live Background Removal Lite</b> aus.</li>
<li>Der Filter wird zu deiner Quelle hinzugefügt, und du kannst seine Eigenschaften nun nach Bedarf anpassen.</li>
</ol>
</section>

<section id="basic-properties">
<h2>Grundlegende Eigenschaften</h2>
<ul>
<li><b>Plugin-Status</b>: Der obere Abschnitt zeigt den aktuellen Aktualisierungsstatus des Plugins an.</li>
<li>
<b>Filterstufe</b>: Wählt die Verarbeitungsstufe für die Hintergrundentfernung aus. <br />
<ul>
<li><b>Passthrough</b>: Keine Hintergrundentfernung, die Quelle wird unverändert angezeigt.</li>
<li><b>Segmentation</b>: Wendet eine einfache Segmentierungsmaske an, um den Hintergrund zu entfernen.</li>
<li><b>Motion Intensity Thresholding</b>: Wendet die Segmentierung nur an, wenn eine Bewegung oberhalb eines Schwellwerts erkannt wird.</li>
<li><b>Guided Filter</b>: Verfeinert die Maskenkanten mit einem Guided Filter für bessere Qualität.</li>
<li><b>Time Averaged Filter</b>: Glättet und stabilisiert die Maske über die Zeit weiter für die höchste Schnittqualität.</li>
</ul>
</li>
<li>
<b>Motion Intensity Threshold [dB]</b>: Bestimmt die Bewegungsempfindlichkeit, die die KI auslöst. Wenn du diesen Wert senkst, wird das System unempfindlicher und die Last sinkt. <br />
<em>Tipp: Stelle diesen Wert so niedrig wie möglich ein, solange die Maskenverfolgung beim Bewegen noch korrekt bleibt.</em>
</li>
<li>
<b>Motion Tracking Speed</b>: Passt den Filter an, um Flackern zu unterdrücken.
<ul>
<li><b>Niedrigere Werte</b>: Weniger Flackern, aber mehr Maskenlatenz (Verzögerung).</li>
<li><b>Höhere Werte</b>: Schnellere Reaktion der Verfolgung, aber möglicherweise mehr Flackern.</li>
<li><b>0</b>: Die Maske bewegt sich nicht mehr.</li>
<li><b>1</b>: Deaktiviert den Filter vollständig.</li>
</ul>
</li>
</ul>
</section>

<section id="advanced-properties">
<h2>Erweiterte Eigenschaften</h2>
<p>
Um die erweiterten Konfigurationen zu ändern, musst du das Kontrollkästchen <b>Erweiterte Einstellungen</b> aktivieren.<br />
<em>Hinweis: Wenn dieses Kontrollkästchen nicht aktiviert ist, werden alle Einstellungen unten auf ihre Standardwerte erzwungen.</em>
</p>

<ul>
<li><b>Guided Filter Eps [dB]</b>: Steuert den Epsilon-Parameter des Guided Filters. Dies gleicht Glättung und Kantenerhalt aus. Passe dies an, wenn feine Details zu unscharf oder zu verrauscht aussehen.</li>
<li>
<b>Mask Gamma</b>: Steuert die Härte der Kante.
<ul>
<li><b>&gt; 1.0</b>: Macht Kanten schärfer/dünner (choke).</li>
<li><b>&lt; 1.0</b>: Macht Kanten weicher/dicker (spread).</li>
<li><em>Typischer Wert: 1.5 - 2.5</em></li>
</ul>
</li>
<li>
<b>Mask Lower Bound [dB]</b> &amp; <b>Mask Upper Bound Margin [dB]</b>: Diese Parameter verhindern mehrdeutige Halbdurchsichtigkeit und verbessern so die Qualität des Schnitts.
<ul>
<li><b>Lower Bound</b>: Pixel unterhalb dieses Werts werden vollständig transparent. Steuert die <b>Halo-Entfernung</b>.</li>
<li><b>Upper Bound Margin</b>: Pixel oberhalb dieses Werts werden vollständig undurchsichtig. Steuert die <b>Kernsolidität</b>.</li>
</ul>
</li>
</ul>
</section>

<nav aria-label="Seitennavigation">
<a href={withTrailingSlash(joinURL(BASE_URL, lang))}>Zurück nach oben</a>
</nav>
</main>

