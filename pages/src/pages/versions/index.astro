import { joinURL, withTrailingSlash } from "ufo";
import { Octokit } from "@octokit/core";
import { paginateRest } from "@octokit/plugin-paginate-rest";

import { defaultContentSecurityPolicy } from "../../lib/csp.mjs";
import { GITHUB_OWNER, GITHUB_REPO, GITHUB_URL, PRODUCTION_BASE_URL } from "../../lib/info.mjs";
import { getLatestRelease, listReleases } from "../../lib/github.mjs";

const { BASE_URL, PROD } = import.meta.env;
const GITHUB_SHA = import.meta.env.GITHUB_SHA?.trim();

const MyOctokit = Octokit.plugin(paginateRest);
const octokit = new MyOctokit({ auth: import.meta.env.GITHUB_TOKEN });

const allReleases = await listReleases(octokit);
const latestRelease = await getLatestRelease(octokit);

const validReleases = allReleases.filter((release) => !release.draft && release.published_at && release.id !== latestRelease.id);
---

<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
{ PROD && (<meta http-equiv="Content-Security-Policy" content={defaultContentSecurityPolicy.join(" ")} />) }
<title>Versions - Live Background Removal Lite</title>
<meta name="description" content="Official release archive for Live Background Removal Lite. Access all past versions, release notes, and download links in one place." />
<meta name="viewport" content="width=device-width" />
<meta name="revision" content={GITHUB_SHA ?? "undefined"} />
<meta name="github-repo" content="kaito-tokyo/live-backgroundremoval-lite" />
<link rel="icon" type="image/svg+xml" href={joinURL(BASE_URL, "favicon.svg")} />
<link rel="shortcut icon" href={joinURL(BASE_URL, "favicon.ico")} />
<link rel="stylesheet" href={joinURL(BASE_URL, "styles", "global.css")} />
<link rel="canonical" href={withTrailingSlash(joinURL(PRODUCTION_BASE_URL, "versions"))} />
<script is:inline src={joinURL(BASE_URL, "scripts", "LocalDate.js")}></script>
</head>
<body id="site-versions-index">
<main class="white-box">

<hgroup>
<h1>Version History</h1>
<h2>Live Background Removal Lite</h2>
</hgroup>

<h2>Latest Release</h2>
<p id="latest-release">
<a href={withTrailingSlash(joinURL(BASE_URL, "versions", latestRelease.tag_name))}><b>{latestRelease.tag_name}</b>
(<local-date data-date={latestRelease.published_at}><time datetime={latestRelease.published_at}>{latestRelease.published_at}</time></local-date>)</a>
</p>

<nav aria-label="Page navigation">
<a href={withTrailingSlash(BASE_URL)}>Back to Top</a> |
<a href={withTrailingSlash(GITHUB_URL)} target="_blank" rel="noopener noreferrer">GitHub Repository</a>
</nav>

<hr />

<h2>Past Versions</h2>
<ul>
{ validReleases.map((release) => (
<li>
<a href={withTrailingSlash(joinURL(BASE_URL, "versions", release.tag_name))}>
<b>{release.tag_name}</b>
(<local-date data-date={release.published_at}><time datetime={release.published_at}>{release.published_at}</time></local-date>)</a>
</li>
)) }
</ul>
</main>

<footer>
<a href={`https://github.com/${GITHUB_OWNER}/${GITHUB_REPO}/actions/workflows/daily-website-security-check.yml`} target="_blank" rel="noopener noreferrer"><img src={`https://github.com/${GITHUB_OWNER}/${GITHUB_REPO}/actions/workflows/daily-website-security-check.yml/badge.svg`} alt="Daily Website Security Check" /></a>
&copy; 2025-2026 Kaito Udagawa
</footer>

<script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token":"0df4a48356ba406099ae721158ab230b"}'></script>
</body>
</html>
