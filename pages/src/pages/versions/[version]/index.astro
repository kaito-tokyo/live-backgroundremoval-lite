import { joinURL, withTrailingSlash } from "ufo";
import { Octokit } from "@octokit/core";
import { paginateRest } from "@octokit/plugin-paginate-rest";

import { defaultContentSecurityPolicy } from "../../../lib/csp.mjs";
import { GITHUB_OWNER, GITHUB_REPO, GITHUB_URL, PRODUCTION_BASE_URL, MATRIX_CHATROOM_URL } from "../../../lib/info.mjs";
import { getLatestRelease, listReleases } from "../../../lib/github.mjs";

export async function getStaticPaths() {
  const MyOctokit = Octokit.plugin(paginateRest);
  const octokit = new MyOctokit({ auth: import.meta.env.GITHUB_TOKEN });

  const allReleases = await listReleases(octokit);
  const latestRelease = await getLatestRelease(octokit);

  return allReleases.flatMap((release) => {
    if (release.draft || !release.published_at) {
      return [];
    } else {
      return [{
        params: { version: release.tag_name },
        props: { release, isLatestRelease: release.id === latestRelease.id },
      }];
    }
  });
}

const { BASE_URL, PROD } = import.meta.env;
const GITHUB_SHA = import.meta.env.GITHUB_SHA?.trim();

const { version } = Astro.params;
const { release, isLatestRelease } = Astro.props;

function stripMarkdown(markdown: string): string {
  return markdown
    .replace(/^#+\s+/gm, "")
    .replace(/^[\s\-*+]+/gm, "")
    .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
    .replace(/```/g, "")
    .replace(/[*_]{1,2}([^*_]+)[*_]{1,2}/g, "$1")
    .replace(/\s+/g, " ")
    .trim();
}

let description = `Download version ${release.tag_name} of Live Background Removal Lite.`;
if (release.body) {
  const maxLength = 160;
  const cleanBody = stripMarkdown(release.body);
  description += ` Highlights: ${cleanBody.substring(0, maxLength)}`;
  if (cleanBody.length > maxLength) {
    description += "...";
  }
}
---

<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
{ PROD && (<meta http-equiv="Content-Security-Policy" content={defaultContentSecurityPolicy.join(" ")} />) }
<title>{`Live Background Removal Lite ${version}`}</title>
<meta name="description" content={description} />
<meta name="viewport" content="width=device-width" />
<meta name="revision" content={GITHUB_SHA ?? "undefined"} />
<meta name="github-repo" content={`${GITHUB_OWNER}/${GITHUB_REPO}`} />
<link rel="icon" type="image/svg+xml" href={joinURL(BASE_URL, "favicon.svg")} />
<link rel="shortcut icon" href={joinURL(BASE_URL, "favicon.ico")} />
<link rel="stylesheet" href={joinURL(BASE_URL, "styles", "global.css")} />
<link rel="canonical" href={withTrailingSlash(joinURL(PRODUCTION_BASE_URL, "versions", version))} />
<script is:inline src={joinURL(BASE_URL, "scripts", "LocalDate.js")}></script>
</head>
<body id="site-versions-version">
<main class="white-box">

<article>
<hgroup class="version-header">
<div class="version-title-row">
<h1>Version {version}</h1>
{ isLatestRelease && (<span class="badge-latest">Latest</span>) }
</div>
<h2>Live Background Removal Lite</h2>
</hgroup>

{
release.prerelease && (
<aside class="alert-box" aria-label="Version stability warning">
<p><b>Pre-release:</b> This version is unstable. Not recommended for use.</p>
</aside>
)
}

<section class="release-notes">
<pre>{release.body ?? "No release notes available."}</pre>
</section>

<section class="downloads-section">
<ul class="download-links">
<li><a href={`https://github.com/kaito-tokyo/live-backgroundremoval-lite/releases/tag/${release.tag_name}#:~:text=%2Dwindows%2Dx64.zip`}>Windows</a></li>
<li><a href={`https://github.com/kaito-tokyo/live-backgroundremoval-lite/releases/tag/${release.tag_name}#:~:text=%2Dmacos%2Duniversal.pkg`}>macOS</a></li>
<li><a href={`https://github.com/kaito-tokyo/live-backgroundremoval-lite/releases/tag/${release.tag_name}#:~:text=%2Dx86_64%2Dlinux-gnu.deb`}>Ubuntu</a></li>
<li><a href="https://github.com/kaito-tokyo/live-backgroundremoval-lite/tree/main/unsupported/arch">Arch Linux</a></li>
<li><a href="https://github.com/kaito-tokyo/live-backgroundremoval-lite/tree/main/unsupported/flatpak">Flatpak</a></li>
<li><a href="https://github.com/kaito-tokyo/live-backgroundremoval-lite/tree/main/docs/fedora">Fedora</a></li>
</ul>
</section>

<section class="material-buttons">
<div class="github-button">
<a href={release.html_url} target="_blank" rel="noopener noreferrer">
<img src={joinURL(BASE_URL, "github-mark-white.svg")} width="24" height="24" alt="GitHub" />
<span>View on GitHub</span>
</a>
</div>
<div class="matrix-chatroom-button">
<a href={MATRIX_CHATROOM_URL} target="_blank" rel="noopener noreferrer">
<span>Join Matrix Chat Room</span>
</a>
</div>
</section>

</article>

<nav aria-label="Page navigation">
<a href={withTrailingSlash(BASE_URL)}>Back to Top</a> |
<a href={withTrailingSlash(joinURL(BASE_URL, "versions"))}>Back to Version History</a> |
<a href={withTrailingSlash(GITHUB_URL)} target="_blank" rel="noopener noreferrer">GitHub Repository</a>
</nav>
</main>

<footer>
<a href={`https://github.com/${GITHUB_OWNER}/${GITHUB_REPO}/actions/workflows/daily-website-security-check.yml`} target="_blank" rel="noopener noreferrer"><img src={`https://github.com/${GITHUB_OWNER}/${GITHUB_REPO}/actions/workflows/daily-website-security-check.yml/badge.svg`} alt="Daily Website Security Check" /></a>
&copy; 2025-2026 Kaito Udagawa
</footer>

<script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token":"0df4a48356ba406099ae721158ab230b"}'></script>
</body>
</html>
