import { joinURL, withTrailingSlash } from "ufo";

import { GITHUB_OWNER, GITHUB_REPO, PRODUCTION_BASE_URL } from "../../lib/info.mjs";

const { BASE_URL, PROD } = import.meta.env;
const GITHUB_SHA = import.meta.env.GITHUB_SHA?.trim();

const lang = "es-es";
const localizedBaseURL = withTrailingSlash(joinURL(BASE_URL, lang));
const canonicalURL = withTrailingSlash(joinURL(PRODUCTION_BASE_URL, lang, "usage"));

const cspContent = [
  "default-src 'self';",

  "connect-src 'self' https://cloudflareinsights.com;",
  "img-src 'self' data: https://github.com/kaito-tokyo/live-backgroundremoval-lite/actions/workflows/daily-website-security-check.yml/badge.svg;",
  "script-src 'self' https://static.cloudflareinsights.com;",
  "style-src 'self';",

  "base-uri 'none';",
  "font-src 'self';",
  "form-action 'self';",
  "frame-src 'none';",
  "manifest-src 'self';",
  "object-src 'none';",
  "upgrade-insecure-requests;",
  "worker-src 'self';"
];
---

<!doctype html>
<html lang="es-es">
<head>
<meta charset="utf-8" />
{ PROD && (<meta http-equiv="Content-Security-Policy" content={cspContent.join(" ")} />) }
<title>Uso - Live Background Removal Lite</title>
<meta name="description" content="Una eliminación de fondo de alto rendimiento, resistente a fallos y pensada primero para juegos en OBS Studio." />
<meta name="viewport" content="width=device-width" />
<meta name="revision" content={GITHUB_SHA ?? "undefined"} />
<meta name="github-repo" content="kaito-tokyo/live-backgroundremoval-lite" />
<link rel="icon" type="image/svg+xml" href={joinURL(BASE_URL, "favicon.svg")} />
<link rel="shortcut icon" href={joinURL(BASE_URL, "favicon.ico")} />
<link rel="stylesheet" href={joinURL(BASE_URL, "styles", "global.css")} />
<link rel="preload" as="image" href={joinURL(BASE_URL, "demo.webp")} />
<link rel="canonical" href={canonicalURL} />
</head>
<body id="site-usage">
<main class="white-box">

<hgroup>
<h1>Uso</h1>
<h2>Live Background Removal Lite</h2>
</hgroup>

<nav class="langs" aria-label="Idioma">
<a href={withTrailingSlash(joinURL(BASE_URL, "usage"))} lang="en">Global</a> |
<a href={withTrailingSlash(joinURL(BASE_URL, "de-de", "usage"))} lang="de-de">Deutsch</a> |
<span lang="es-es">Español</span> |
<a href={withTrailingSlash(joinURL(BASE_URL, "fr-fr", "usage"))} lang="fr-fr">Français</a> |
<a href={withTrailingSlash(joinURL(BASE_URL, "ko-kr", "usage"))} lang="ko-kr">한국어</a> |
<a href={withTrailingSlash(joinURL(BASE_URL, "ja-jp", "usage"))} lang="ja-jp">日本語</a> |
<a href={withTrailingSlash(joinURL(BASE_URL, "pt-br", "usage"))} lang="pt-br">Português (Brasil)</a> |
<a href={withTrailingSlash(joinURL(BASE_URL, "ru-ru", "usage"))} lang="ru-ru">Русский</a> |
<a href={withTrailingSlash(joinURL(BASE_URL, "zh-cn", "usage"))} lang="zh-cn">简体中文</a> |
<a href={withTrailingSlash(joinURL(BASE_URL, "zh-tw", "usage"))} lang="zh-tw">繁體中文</a>
</nav>

<section id="adding-filter">
<h2>Agregar el filtro</h2>
<img
src={joinURL(BASE_URL, "effect-filters.webp")}
alt="Captura de la ventana de filtros de OBS Studio, mostrando la selección de 'Live Background Removal Lite' en la lista de filtros de efectos."
width="1552"
height="1032"
fetchpriority="high"
/
>
<ol>
<li>En OBS Studio, haz clic con el botón derecho sobre tu fuente de video, por ejemplo tu cámara web, en el panel "Fuentes".</li>
<li>Selecciona <b>Filtros</b> en el menú contextual.</li>
<li>En la ventana "Filtros", dentro de la sección "Filtros de efectos", haz clic en el botón <b>+</b> para agregar un filtro nuevo.</li>
<li>De la lista de filtros disponibles, selecciona <b>Live Background Removal Lite</b>.</li>
<li>El filtro se agregará a tu fuente y ahora podrás ajustar sus propiedades según sea necesario.</li>
</ol>
</section>

<section id="basic-properties">
<h2>Propiedades básicas</h2>
<ul>
<li><b>Estado del plugin</b>: La sección superior muestra el estado actual de actualización del plugin.</li>
<li>
<b>Nivel de filtro</b>: Selecciona la etapa de procesamiento para la eliminación de fondo. <br />
<ul>
<li><b>Passthrough</b>: No hay eliminación de fondo, la fuente se muestra tal cual.</li>
<li><b>Segmentation</b>: Aplica una máscara de segmentación básica para eliminar el fondo.</li>
<li><b>Motion Intensity Thresholding</b>: Solo aplica la segmentación cuando se detecta movimiento por encima de un umbral.</li>
<li><b>Guided Filter</b>: Refina los bordes de la máscara usando un filtro guiado para obtener mejor calidad.</li>
<li><b>Time Averaged Filter</b>: Suaviza y estabiliza aún más la máscara con el tiempo para lograr el recorte de mayor calidad.</li>
</ul>
</li>
<li>
<b>Motion Intensity Threshold [dB]</b>: Determina la sensibilidad al movimiento que activa la IA. Bajar este valor la hace menos sensible y reduce la carga. <br />
<em>Consejo: ajusta este valor tan bajo como sea posible mientras mantienes un seguimiento correcto de la máscara al moverte.</em>
</li>
<li>
<b>Motion Tracking Speed</b>: Ajusta el filtro para reducir el parpadeo.
<ul>
<li><b>Valores bajos</b>: Menos parpadeo, pero aumenta la latencia de la máscara (retardo).</li>
<li><b>Valores altos</b>: Respuesta de seguimiento más rápida, pero puede aumentar el parpadeo.</li>
<li><b>0</b>: La máscara deja de moverse.</li>
<li><b>1</b>: Desactiva el filtro por completo.</li>
</ul>
</li>
</ul>
</section>

<section id="advanced-properties">
<h2>Propiedades avanzadas</h2>
<p>
Para modificar las configuraciones extendidas, debes activar la casilla <b>Advanced Settings</b>.<br />
<em>Nota: cuando esta casilla está desmarcada, todos los ajustes siguientes se fuerzan a sus valores predeterminados.</em>
</p>

<ul>
<li><b>Guided Filter Eps [dB]</b>: Controla el parámetro epsilon del Guided Filter. Esto equilibra el suavizado frente a la preservación de bordes. Ajusta este valor si los detalles finos se ven demasiado borrosos o con ruido.</li>
<li>
<b>Mask Gamma</b>: Controla la dureza del borde.
<ul>
<li><b>&gt; 1.0</b>: Hace los bordes más nítidos/delgados (choke).</li>
<li><b>&lt; 1.0</b>: Hace los bordes más suaves/gruesos (spread).</li>
<li><em>Valor típico: 1.5 - 2.5</em></li>
</ul>
</li>
<li>
<b>Mask Lower Bound [dB]</b> &amp; <b>Mask Upper Bound Margin [dB]</b>: Estos parámetros evitan la semitransparencia ambigua para mejorar la calidad del recorte.
<ul>
<li><b>Lower Bound</b>: Los píxeles por debajo de este nivel se vuelven completamente transparentes. Controla la <b>eliminación de halo</b>.</li>
<li><b>Upper Bound Margin</b>: Los píxeles por encima de este nivel se vuelven completamente opacos. Controla la <b>solidez del núcleo</b>.</li>
</ul>
</li>
</ul>
</section>

<nav class="page-nav" aria-label="Navegación de la página">
<ul>
<li>
<a href={withTrailingSlash(localizedBaseURL)}>Volver al inicio</a>
</li>
</ul>
</nav>
</main>

