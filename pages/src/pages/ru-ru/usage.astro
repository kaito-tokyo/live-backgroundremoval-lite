import { joinURL, withTrailingSlash } from "ufo";

import { defaultContentSecurityPolicy } from "../../lib/csp.mjs";
import { GITHUB_OWNER, GITHUB_REPO, PRODUCTION_BASE_URL } from "../../lib/info.mjs";

const { BASE_URL, PROD } = import.meta.env;
const GITHUB_SHA = import.meta.env.GITHUB_SHA?.trim();

const lang = "ru-ru";
---

<!doctype html>
<html lang="ru-ru">
<head>
<meta charset="utf-8" />
{ PROD && (<meta http-equiv="Content-Security-Policy" content={defaultContentSecurityPolicy.join(" ")} />) }
<title>Использование - Live Background Removal Lite</title>
<meta name="description" content="Высокопроизводительное, устойчивое к сбоям удаление фона для OBS Studio с приоритетом игр." />
<meta name="viewport" content="width=device-width" />
<meta name="revision" content={GITHUB_SHA ?? "undefined"} />
<meta name="github-repo" content="kaito-tokyo/live-backgroundremoval-lite" />
<link rel="icon" type="image/svg+xml" href={joinURL(BASE_URL, "favicon.svg")} />
<link rel="shortcut icon" href={joinURL(BASE_URL, "favicon.ico")} />
<link rel="stylesheet" href={joinURL(BASE_URL, "styles", "global.css")} />
<link rel="canonical" href={withTrailingSlash(joinURL(PRODUCTION_BASE_URL, lang, "usage"))} />
</head>
<body id="site-usage">
<main class="white-box">

<hgroup>
<h1>Использование</h1>
<h2>Live Background Removal Lite</h2>
</hgroup>

<nav class="langs" aria-label="Язык">
<a href={withTrailingSlash(joinURL(BASE_URL, "usage"))} lang="en">Global</a> |
<a href={withTrailingSlash(joinURL(BASE_URL, "de-de", "usage"))} lang="de-de">Deutsch</a> |
<a href={withTrailingSlash(joinURL(BASE_URL, "es-es", "usage"))} lang="es-es">Español</a> |
<a href={withTrailingSlash(joinURL(BASE_URL, "fr-fr", "usage"))} lang="fr-fr">Français</a> |
<a href={withTrailingSlash(joinURL(BASE_URL, "ko-kr", "usage"))} lang="ko-kr">한국어</a> |
<a href={withTrailingSlash(joinURL(BASE_URL, "ja-jp", "usage"))} lang="ja-jp">日本語</a> |
<a href={withTrailingSlash(joinURL(BASE_URL, "pt-br", "usage"))} lang="pt-br">Português (Brasil)</a> |
<span lang="ru-ru">Русский</span> |
<a href={withTrailingSlash(joinURL(BASE_URL, "zh-cn", "usage"))} lang="zh-cn">简体中文</a> |
<a href={withTrailingSlash(joinURL(BASE_URL, "zh-tw", "usage"))} lang="zh-tw">繁體中文</a>
</nav>

<section id="adding-filter">
<h2>Добавление фильтра</h2>
<img
src={joinURL(BASE_URL, "effect-filters.webp")}
alt="Скриншот окна фильтров OBS Studio, показывающий выбор 'Live Background Removal Lite' в списке эффект-фильтров."
width="1552"
height="1032"
fetchpriority="high"
/
>
<ol>
<li>В OBS Studio щелкните правой кнопкой мыши по вашему видеисточнику, например веб-камере, в панели "Источники".</li>
<li>Выберите <b>Фильтры</b> в контекстном меню.</li>
<li>В окне "Фильтры", в разделе "Эффект-фильтры", нажмите кнопку <b>+</b>, чтобы добавить новый фильтр.</li>
<li>Из списка доступных фильтров выберите <b>Live Background Removal Lite</b>.</li>
<li>Фильтр будет добавлен к вашему источнику, и вы сможете настроить его свойства по мере необходимости.</li>
</ol>
</section>

<section id="basic-properties">
<h2>Основные свойства</h2>
<ul>
<li><b>Статус плагина</b>: В верхнем разделе отображается текущий статус обновления плагина.</li>
<li>
<b>Уровень фильтра</b>: Выбирает этап обработки для удаления фона. <br />
<ul>
<li><b>Passthrough</b>: Удаление фона не выполняется, источник показывается как есть.</li>
<li><b>Segmentation</b>: Применяет базовую маску сегментации для удаления фона.</li>
<li><b>Motion Intensity Thresholding</b>: Применяет сегментацию только тогда, когда движение превышает порог.</li>
<li><b>Guided Filter</b>: Уточняет края маски с помощью guided filter для лучшего качества.</li>
<li><b>Time Averaged Filter</b>: Дополнительно сглаживает и стабилизирует маску во времени для наилучшего качества вырезки.</li>
</ul>
</li>
<li>
<b>Motion Intensity Threshold [dB]</b>: Определяет чувствительность к движению, которая запускает ИИ. Уменьшение этого значения делает его менее чувствительным и снижает нагрузку. <br />
<em>Совет: уменьшайте это значение как можно сильнее, сохраняя точное отслеживание маски при движении.</em>
</li>
<li>
<b>Motion Tracking Speed</b>: Настраивает фильтр для подавления мерцания.
<ul>
<li><b>Низкие значения</b>: Меньше мерцания, но увеличивается задержка маски.</li>
<li><b>Высокие значения</b>: Более быстрая реакция отслеживания, но мерцание может усилиться.</li>
<li><b>0</b>: Маска перестает двигаться.</li>
<li><b>1</b>: Полностью отключает фильтр.</li>
</ul>
</li>
</ul>
</section>

<section id="advanced-properties">
<h2>Дополнительные свойства</h2>
<p>
Чтобы изменить расширенные настройки, необходимо включить флажок <b>Advanced Settings</b>.<br />
<em>Примечание: когда этот флажок снят, все настройки ниже принудительно принимают значения по умолчанию.</em>
</p>

<ul>
<li><b>Guided Filter Eps [dB]</b>: Управляет параметром epsilon у Guided Filter. Это баланс между сглаживанием и сохранением краев. Настройте это, если мелкие детали выглядят слишком размытыми или шумными.</li>
<li>
<b>Mask Gamma</b>: Управляет жесткостью края.
<ul>
<li><b>&gt; 1.0</b>: Делает края более четкими и тонкими (choke).</li>
<li><b>&lt; 1.0</b>: Делает края более мягкими и толстыми (spread).</li>
<li><em>Типичное значение: 1.5 - 2.5</em></li>
</ul>
</li>
<li>
<b>Mask Lower Bound [dB]</b> &amp; <b>Mask Upper Bound Margin [dB]</b>: Эти параметры предотвращают неоднозначную полупрозрачность, улучшая качество вырезки.
<ul>
<li><b>Lower Bound</b>: Пиксели ниже этого уровня становятся полностью прозрачными. Управляет <b>удалением ореола</b>.</li>
<li><b>Upper Bound Margin</b>: Пиксели выше этого уровня становятся полностью непрозрачными. Управляет <b>плотностью ядра</b>.</li>
</ul>
</li>
</ul>
</section>

<nav aria-label="Навигация по странице">
<a href={withTrailingSlash(joinURL(BASE_URL, lang))}>Вернуться наверх</a>
</nav>
</main>

