import { joinURL, withTrailingSlash } from "ufo";

import { GITHUB_OWNER, GITHUB_REPO, PRODUCTION_BASE_URL } from "../../lib/info.mjs";

const { BASE_URL, PROD } = import.meta.env;
const GITHUB_SHA = import.meta.env.GITHUB_SHA?.trim();

const lang = "ko-kr";
const localizedBaseURL = withTrailingSlash(joinURL(BASE_URL, lang));
const canonicalURL = withTrailingSlash(joinURL(PRODUCTION_BASE_URL, lang, "usage"));

const cspContent = [
  "default-src 'self';",

  "connect-src 'self' https://cloudflareinsights.com;",
  "img-src 'self' data: https://github.com/kaito-tokyo/live-backgroundremoval-lite/actions/workflows/daily-website-security-check.yml/badge.svg;",
  "script-src 'self' https://static.cloudflareinsights.com;",
  "style-src 'self';",

  "base-uri 'none';",
  "font-src 'self';",
  "form-action 'self';",
  "frame-src 'none';",
  "manifest-src 'self';",
  "object-src 'none';",
  "upgrade-insecure-requests;",
  "worker-src 'self';"
];
---

<!doctype html>
<html lang="ko-kr">
<head>
<meta charset="utf-8" />
{ PROD && (<meta http-equiv="Content-Security-Policy" content={cspContent.join(" ")} />) }
<title>사용법 - Live Background Removal Lite</title>
<meta name="description" content="OBS Studio를 위한 게이밍 우선, 고성능, 충돌에 강한 배경 제거입니다." />
<meta name="viewport" content="width=device-width" />
<meta name="revision" content={GITHUB_SHA ?? "undefined"} />
<meta name="github-repo" content="kaito-tokyo/live-backgroundremoval-lite" />
<link rel="icon" type="image/svg+xml" href={joinURL(BASE_URL, "favicon.svg")} />
<link rel="shortcut icon" href={joinURL(BASE_URL, "favicon.ico")} />
<link rel="stylesheet" href={joinURL(BASE_URL, "styles", "global.css")} />
<link rel="preload" as="image" href={joinURL(BASE_URL, "demo.webp")} />
<link rel="canonical" href={canonicalURL} />
</head>
<body id="site-usage">
<main class="white-box">

<hgroup>
<h1>사용법</h1>
<h2>Live Background Removal Lite</h2>
</hgroup>

<nav class="langs" aria-label="언어">
<a href={withTrailingSlash(joinURL(BASE_URL, "usage"))} lang="en">Global</a> |
<a href={withTrailingSlash(joinURL(BASE_URL, "de-de", "usage"))} lang="de-de">Deutsch</a> |
<a href={withTrailingSlash(joinURL(BASE_URL, "es-es", "usage"))} lang="es-es">Español</a> |
<a href={withTrailingSlash(joinURL(BASE_URL, "fr-fr", "usage"))} lang="fr-fr">Français</a> |
<span lang="ko-kr">한국어</span> |
<a href={withTrailingSlash(joinURL(BASE_URL, "ja-jp", "usage"))} lang="ja-jp">日本語</a> |
<a href={withTrailingSlash(joinURL(BASE_URL, "pt-br", "usage"))} lang="pt-br">Português (Brasil)</a> |
<a href={withTrailingSlash(joinURL(BASE_URL, "ru-ru", "usage"))} lang="ru-ru">Русский</a> |
<a href={withTrailingSlash(joinURL(BASE_URL, "zh-cn", "usage"))} lang="zh-cn">简体中文</a> |
<a href={withTrailingSlash(joinURL(BASE_URL, "zh-tw", "usage"))} lang="zh-tw">繁體中文</a>
</nav>

<section id="adding-filter">
<h2>필터 추가</h2>
<img
src={joinURL(BASE_URL, "effect-filters.webp")}
alt="OBS Studio 필터 창의 스크린샷으로, 효과 필터 목록에서 'Live Background Removal Lite'를 선택하는 모습."
width="1552"
height="1032"
fetchpriority="high"
/
>
<ol>
<li>OBS Studio의 "소스" 패널에서 웹캠과 같은 비디오 소스를 마우스 오른쪽 버튼으로 클릭합니다.</li>
<li>컨텍스트 메뉴에서 <b>필터</b>를 선택합니다.</li>
<li>"필터" 창의 "효과 필터" 섹션에서 <b>+</b> 버튼을 클릭하여 새 필터를 추가합니다.</li>
<li>사용 가능한 필터 목록에서 <b>Live Background Removal Lite</b>를 선택합니다.</li>
<li>필터가 소스에 추가되며, 이제 필요에 따라 속성을 조정할 수 있습니다.</li>
</ol>
</section>

<section id="basic-properties">
<h2>기본 속성</h2>
<ul>
<li><b>플러그인 상태</b>: 상단 섹션에 플러그인의 현재 업데이트 상태가 표시됩니다.</li>
<li>
<b>필터 레벨</b>: 배경 제거의 처리 단계를 선택합니다. <br />
<ul>
<li><b>Passthrough</b>: 배경 제거를 하지 않고 소스를 그대로 표시합니다.</li>
<li><b>Segmentation</b>: 기본 세분화 마스크를 적용하여 배경을 제거합니다.</li>
<li><b>Motion Intensity Thresholding</b>: 동작이 임계값을 넘을 때만 세분화를 적용합니다.</li>
<li><b>Guided Filter</b>: 가이드 필터로 마스크 가장자리를 다듬어 더 나은 품질을 제공합니다.</li>
<li><b>Time Averaged Filter</b>: 마스크를 시간에 따라 더 부드럽고 안정적으로 만들어 가장 높은 품질의 컷아웃을 제공합니다.</li>
</ul>
</li>
<li>
<b>Motion Intensity Threshold [dB]</b>: AI를 트리거할 움직임 민감도를 결정합니다. 이 값을 낮추면 덜 민감해지고 부하가 줄어듭니다. <br />
<em>팁: 움직일 때 정확한 마스크 추적을 유지할 수 있는 범위에서 이 값을 가능한 한 낮게 조정하세요.</em>
</li>
<li>
<b>Motion Tracking Speed</b>: 깜박임을 줄이도록 필터를 조정합니다.
<ul>
<li><b>낮은 값</b>: 깜박임은 줄지만 마스크 지연(렉)이 증가합니다.</li>
<li><b>높은 값</b>: 추적 반응이 더 빠르지만 깜박임이 늘 수 있습니다.</li>
<li><b>0</b>: 마스크가 움직이지 않습니다.</li>
<li><b>1</b>: 필터를 완전히 비활성화합니다.</li>
</ul>
</li>
</ul>
</section>

<section id="advanced-properties">
<h2>고급 속성</h2>
<p>
확장 설정을 수정하려면 <b>Advanced Settings</b> 체크박스를 활성화해야 합니다.<br />
<em>참고: 이 체크박스가 꺼져 있으면 아래의 모든 설정은 기본값으로 강제됩니다.</em>
</p>

<ul>
<li><b>Guided Filter Eps [dB]</b>: Guided Filter의 epsilon 매개변수를 제어합니다. 이는 부드러움과 가장자리 보존 사이의 균형을 맞춥니다. 세부 부분이 너무 흐리거나 노이즈가 많아 보일 때 조정하세요.</li>
<li>
<b>Mask Gamma</b>: 가장자리의 단단함을 제어합니다.
<ul>
<li><b>&gt; 1.0</b>: 가장자리를 더 선명하고 얇게 만듭니다(choke).</li>
<li><b>&lt; 1.0</b>: 가장자리를 더 부드럽고 두껍게 만듭니다(spread).</li>
<li><em>일반적인 값: 1.5 - 2.5</em></li>
</ul>
</li>
<li>
<b>Mask Lower Bound [dB]</b> &amp; <b>Mask Upper Bound Margin [dB]</b>: 애매한 반투명 영역을 방지해 컷아웃 품질을 높이는 매개변수입니다.
<ul>
<li><b>Lower Bound</b>: 이 수준 아래의 픽셀은 완전히 투명해집니다. <b>halo removal</b>를 제어합니다.</li>
<li><b>Upper Bound Margin</b>: 이 수준 위의 픽셀은 완전히 불투명해집니다. <b>core solidity</b>를 제어합니다.</li>
</ul>
</li>
</ul>
</section>

<nav class="page-nav" aria-label="페이지 탐색">
<ul>
<li>
<a href={withTrailingSlash(localizedBaseURL)}>맨 위로 돌아가기</a>
</li>
</ul>
</nav>
</main>

